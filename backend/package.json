    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.4",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^2.0.13",
    "jest": "^29.6.0",
    "supertest": "^6.3.3",
